# RELTIVA Environment Variables Template
# Copy this file to .env in your web folder and configure the values.

# DATABASE (PostgreSQL via Prisma ORM)
DATABASE_URL="postgresql://user:password@localhost:5432/reltiva?schema=public"

# AUTHENTICATION (NextAuth.js)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_jwt_secret_key_minimum_32_characters"

# GOOGLE OAUTH
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# IMAGE STORAGE (Cloudinary)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# EMAIL NOTIFICATIONS (Resend)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="Reltiva <no-reply@yourdomain.com>"

# PAYMENTS (Paystack)
PAYSTACK_PUBLIC_KEY="pk_test_your_paystack_public_key"
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key"
PAYSTACK_WEBHOOK_SECRET="your_paystack_webhook_signing_secret"

# MAPS (Google Maps API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_browser_api_key"

# MOBILE APP API (For local development pointing the mobile app to your dev server)
# Set this to your local IP address (e.g., http://192.168.1.100:3000)
NEXT_PUBLIC_API_URL="http://localhost:3000"
